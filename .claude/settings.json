{
  "enabledPlugins": {
    "nano-banana-2@nano-banana-2-plugins": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "mcpServers": {
    "nano-banana-2": {
      "command": "npx",
      "args": [
        "-y",
        "nano-banana-2-mcp@0.1.1"
      ]
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "TWENTY_FIRST_API_KEY": "${TWENTY_FIRST_API_KEY}"
      }
    }
  }
}
